# ---- Data & generated artifacts (live in the working tree, never in git) ----
# Bulk source dumps and converted tables are far too large for GitHub and are
# all reproducible from the scripts in this repo.
*.parquet
*.tar.gz
*.zip
*.csv.gz

# DuckDB catalog (regenerate from views.sql: duckdb lake.duckdb -c ".read views.sql")
*.duckdb
*.duckdb.wal

# Extracted CSV working dirs (e.g. OpenCitations Meta extraction)
opencitations/output_csv_*/
**/csv_tmp/
**/parts/

# Build/run logs
*.log

# DuckDB temp spill directory (PRAGMA temp_directory='.tmp')
.tmp/

# macOS
.DS_Store

# Keep small reference lists that ARE worth versioning, e.g. figsharefiles.txt
!figsharefiles.txt

# SQLite exports
*.sqlite
*.sqlite3

# Bulk/derived TSV (sources and parser outputs are reproducible; keep scripts)
*.tsv
# ...but keep small hand-curated source TSVs that make sandbox examples reproducible
!sandbox/bold-citations/datadoi_cites_workdoi.tsv
# Second-degree harvest is regenerable from the lake (sandbox/bold-citations/second_degree.sql)
sandbox/bold-citations/second_degree_dois.txt

# Catalogue of Life ColDP export — bulk files extracted from export.zip
# (reproducible; export.zip itself is ignored by *.zip above). Keep README.md.
col/*.tsv
col/source/
col/metadata.yaml
col/reference.bib
col/reference.json
col/reference.jsonl

# ROR data dump — bulk files extracted from the zip (zip itself ignored by *.zip)
ror/*.csv
ror/*.json

# Open Funder Registry source RDF (reproducible; ofr/*.tsv/*.parquet ignored above)
ofr/*.rdf

# Crossref API cache + logs (re-fetchable; *.tsv/*.parquet ignored above)
crossref/cache/
crossref/failed.txt

# DataCite Public Data File tar (32 GB; tsv/parquet ignored above)
datacite/*.tar

# Rendered chart specs (regenerable from charts/<name>.sql + .vl.json)
charts/out/
# Vendored Vega JS libs for offline HTML viewing (fetch per charts/README.md)
charts/*.js

# Local Claude Code config (machine-specific paths)
.claude/
